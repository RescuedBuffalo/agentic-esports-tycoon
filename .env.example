# Copy to .env and fill in. Every secret/key the stack reads is listed here.
# Never commit .env. The example is the contract; if a service starts reading a
# new key, add it here in the same PR.

# ---- Postgres (docker-compose `postgres` service) ----------------------------
POSTGRES_USER=nexus
POSTGRES_PASSWORD=nexus
POSTGRES_DB=nexus
POSTGRES_PORT=5432
# DSN consumed by services and migrations.
DATABASE_URL=postgresql://nexus:nexus@localhost:5432/nexus

# ---- Qdrant (docker-compose `qdrant` service) -------------------------------
QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_URL=http://localhost:6333
# Optional: set when running against a hosted Qdrant cluster.
QDRANT_API_KEY=

# ---- Prefect (orchestration profile, Phase 0+) ------------------------------
PREFECT_PORT=4200
PREFECT_API_URL=http://localhost:4200/api

# ---- Data ingest credentials (services/data_pipeline) -----------------------
# VLR doesn't have an official API; scraper hits the public site. Leave blank
# unless you front it with an authenticated proxy.
VLR_PROXY_URL=
RIOT_API_KEY=
LIQUIPEDIA_USER_AGENT=

# ---- LLM / agent backends (services/ecosystem, agent host) ------------------
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ---- Observability ----------------------------------------------------------
# Optional. Leave blank to disable.
SENTRY_DSN=

# ---- Run config -------------------------------------------------------------
# Root seed for the RNG tree (BUF-77). Override per-run for reproducibility.
NEXUS_ROOT_SEED=42
LOG_LEVEL=INFO

# ---- API budget governor (BUF-22) -------------------------------------------
# SQLite ledger location. Defaults to ./.nexus/budget.sqlite under repo root.
NEXUS_BUDGET_DB=.nexus/budget.sqlite
# Hard weekly cap in USD. Calls projected to push spend past this raise
# BudgetExhausted. Default $30 leaves a $10 buffer under the $40 weekly budget.
NEXUS_BUDGET_WEEKLY_HARD_CAP_USD=30.00
# Break-glass override — set to 1/true/yes to disable enforcement entirely.
# Calls still log to the ledger; only the gate is skipped. Use for genuine
# emergencies; every overridden call is annotated in the row's ``notes``.
NEXUS_BUDGET_DISABLE_CAPS=
